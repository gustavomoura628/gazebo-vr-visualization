<?xml version="1.0"?>
<?xml-model href="https://raw.githubusercontent.com/ros2/rcl_interfaces/master/launch_xml/schema/launch.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>

<launch>
  <node pkg="aog_simulation" exec="unitree_sport_mode_adapter" output="screen" />

  <!-- Spawn TurtleBot4 simulation -->
  <include file="$(find-pkg-share turtlebot4_ignition_bringup)/launch/turtlebot4_ignition.launch.py">
    <arg name="gazebo" value="ignition"/>
    <arg name="gz_args" value=""/>
    <arg name="autostart" value="false"/>
    <!-- <arg name="use_respawn" value="true"/> -->
  </include>

  <!-- Bridge the 3D lidar point cloud (rplidar made 3D in the Dockerfile) from gz
       to ROS as /lidar/points. The bringup only bridges the 2D LaserScan /scan. -->
  <node pkg="ros_gz_bridge" exec="parameter_bridge" name="lidar_points_bridge" output="screen"
        args="/world/warehouse/model/turtlebot4/link/rplidar_link/sensor/rplidar/scan/points@sensor_msgs/msg/PointCloud2[ignition.msgs.PointCloudPacked">
    <remap from="/world/warehouse/model/turtlebot4/link/rplidar_link/sensor/rplidar/scan/points" to="/lidar/points"/>
  </node>
</launch>
